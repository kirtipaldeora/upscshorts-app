# Same Supabase project as the Penni app.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-key>

# Public base URL of the `content` storage bucket. Publishing writes here and
# Penni reads from here — this must match Penni's own VITE_CONTENT_BASE.
VITE_CONTENT_BASE=https://<project-ref>.supabase.co/storage/v1/object/public/content
