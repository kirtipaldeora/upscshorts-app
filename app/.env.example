# Supabase — student auth and profiles. Unset means Penni runs in local-only
# mode (guest profiles in localStorage).
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-key>

# Where published content is read from — the public `content` bucket the CMS
# publishes to. Must match admin/.env's VITE_CONTENT_BASE.
#
# Unset means Penni reads only the JSON bundled in the build, exactly as it did
# before the CMS existed. Set it and the bundled files become the offline
# fallback instead. Nothing else in the app changes either way.
VITE_CONTENT_BASE=https://<project-ref>.supabase.co/storage/v1/object/public/content
